#cloud-config
autoinstall:
  version: 1
  identity:
    hostname: cupcake
    username: cupcake
    password: "cupcake"
  ssh:
    install-server: true
    allow-pw: true
    authorized-keys:
      - "SSH_PUBKEY_PLACEHOLDER"
  storage:
    layout:
      name: lvm
  locale: en_US.UTF-8
  keyboard:
    layout: us
  timezone: UTC
  packages:
    - openssh-server
    - curl
    - wget
    - git
    - build-essential
    - python3.12
    - python3.12-venv
    - python3.12-dev
    - libpq-dev
    - nginx
    - postgresql
    - postgresql-client
    - redis-server
    - avahi-daemon
    - avahi-utils
    - unzip
    - ca-certificates
    - ufw
  late-commands:
    - echo "Cupcake appliance installation starting..."
