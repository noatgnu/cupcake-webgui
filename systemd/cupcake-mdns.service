[Unit]
Description=Cupcake mDNS Advertisement
After=network.target nginx.service avahi-daemon.service
Wants=network.target avahi-daemon.service

[Service]
Type=simple
ExecStart=/bin/bash -c "\
    /usr/bin/avahi-publish-service 'Cupcake' _http._tcp 80 'path=/' & \
    /usr/bin/avahi-publish-service 'Cupcake Vanilla' _http._tcp 80 'path=/' & \
    wait"
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
