{
  "name": "cupcake-wails-frontend",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "dev": "ng serve --host 0.0.0.0 --port 4200",
    "build": "ng build --configuration production",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:integration": "playwright test --config=playwright.integration.config.ts",
    "test:integration:headed": "playwright test --config=playwright.integration.config.ts --headed",
    "test:setup-flows": "playwright test --config=playwright.setup-flows.config.ts",
    "test:setup-flows:headed": "playwright test --config=playwright.setup-flows.config.ts --headed",
    "test:all": "npm run test:e2e && npm run test:integration && npm run test:setup-flows"
  },
  "dependencies": {
    "@angular/animations": "21.2.2",
    "@angular/common": "21.2.2",
    "@angular/compiler": "21.2.2",
    "@angular/core": "21.2.2",
    "@angular/forms": "21.2.2",
    "@angular/platform-browser": "21.2.2",
    "@angular/router": "21.2.2",
    "@ng-bootstrap/ng-bootstrap": "20.0.0",
    "@noatgnu/cupcake-core": "^1.3.17",
    "@popperjs/core": "^2.11.8",
    "@wailsio/runtime": "^3.0.0-alpha.79",
    "bootstrap": "^5.3.6",
    "bootstrap-icons": "^1.13.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "21.2.1",
    "@angular/cli": "21.2.1",
    "@angular/compiler-cli": "21.2.2",
    "@angular/localize": "21.2.2",
    "@playwright/test": "^1.58.2",
    "@types/jasmine": "~5.1.0",
    "@types/node": "^22.0.0",
    "jasmine-core": "~5.8.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "~5.9.3"
  }
}
